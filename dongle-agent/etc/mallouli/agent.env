# ==============================================================
# MallouliAuto Dongle Agent - Configuration
# Fichier: /etc/mallouli/agent.env
# 
# ⚠️  IMPORTANT:
#   - Ne pas modifier les fichiers AutoPi. Ce fichier est indépendant.
#   - Les changements nécessitent un restart: sudo systemctl restart mallouli-agent
#   - Permissions: chmod 600 pour la sécurité
#
# Doc AutoPi: https://docs.autopi.io/
# Doc MallouliAuto: https://...
# ==============================================================

# ================================================================
# 1. CONFIGURATION BACKEND MALLOULIAUTO (API Cloud)
# ================================================================

# URL du backend MallouliAuto (votre API FastAPI)
# Exemple: https://api.mallouliauto.tn
# Ou développement: http://localhost:8000
MALLOULI_API_BASE_URL=https://api.mallouliauto.tn

# Identifiant du véhicule dans la base de données backend
# Exemple: 1, 42, 100
# Doit exister dans la table vehicles du backend
MALLOULI_VEHICLE_ID=1

# Identifiant unique du dongle (UUID stable)
# Lisible avec: cat /etc/salt/minion_id
# Ou via API: curl http://127.0.0.1:9000/
# Format: ccb71376cd13b201170ec917fc1199ff (hexadécimal)
MALLOULI_DEVICE_ID=ccb71376cd13b201170ec917fc1199ff

# JWT Bearer Token pour authentifier l'agent auprès du backend
# Généré par: POST /api/v1/auth/login (backend FastAPI)
# Format: eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9....
# Durée de vie: dépend du backend (ex: 24h, 7 jours)
# ⚠️  CHANGEZ CE TOKEN AVEC UN TOKEN VALIDE!
MALLOULI_API_TOKEN=CHANGE_MOI_AVEC_TON_JWT_TOKEN_DU_BACKEND

# ================================================================
# 2. CONFIGURATION API LOCALE AUTOPI (Port 9000)
# ================================================================
#
# L'AutoPi exécute une API REST locale sur port 9000.
# Cette API est utilisée par l'agent pour lire les données OBD.
# Source: https://docs.autopi.io/developer_guides/local-api-overview/
#

# URL de l'API locale AutoPi
# Si exécuté DEPUIS le dongle lui-même: http://127.0.0.1:9000
# Si exécuté d'un autre machine: http://<dongle-ip>:9000
# ⚠️  Ne pas modifier sauf si le port AutoPi est différent (9000 est le défaut)
AUTOPI_LOCAL_API=http://127.0.0.1:9000

# Chemin du fichier contenant le unit_id du dongle (lecture seule)
# Cet ID est utilisé pour:
#   1. Identifier les requêtes au dongle lui-même
#   2. Corréler les données sur le backend
# Lecture: cat /etc/salt/minion_id
AUTOPI_UNIT_ID_FILE=/etc/salt/minion_id

# ================================================================
# 3. PARAMÈTRES DE PERFORMANCE ET RÉSILIENCE
# ================================================================

# Intervalle d'envoi en secondes (boucle principale)
# Valeurs recommandées:
#   - 5s  : Latence très basse (charge réseau importante)
#   - 10s : Équilibre latence/charge (recommandé)
#   - 30s : Basse latence, charge réseau faible
# Trop rapide = surcharge backend. Trop lent = données obsolètes.
PUSH_INTERVAL_SEC=5

# Timeout des requêtes HTTP en secondes
# Si la requête prend plus de cette durée, elle est abandonnée.
# Valeurs recommandées: 5-15s selon la connexion réseau.
REQUEST_TIMEOUT_SEC=10

# Nombre maximum de tentatives en cas d'erreur réseau
# Si backend indisponible, l'agent réessaie jusqu'à MAX_RETRIES fois.
# 1 = pas de retry (risky)
# 3 = défaut (tolérant)
# 5+ = très patient (long delai avant abandon)
MAX_RETRIES=3

# Délai entre les tentatives en secondes (backoff exponentiel)
# Premier retry après RETRY_DELAY_SEC
# Deuxième retry après RETRY_DELAY_SEC * 2
# Etc.
RETRY_DELAY_SEC=2

# Niveau de journalisation (logs)
# Valeurs: DEBUG, INFO, WARNING, ERROR, CRITICAL
# DEBUG   = très verbeux (développement)
# INFO    = infos normales (recommandé production)
# WARNING = seulement avertissements
# ERROR   = seulement erreurs
# Logs écrits dans:
#   - stdout (visible avec journalctl)
#   - /var/log/mallouli/agent.log
#   - /var/log/mallouli/agent.err.log
LOG_LEVEL=INFO

# ================================================================
# NOTES ADDITIONNELLES
# ================================================================
#
# 1. OBTENIR LES PARAMÈTRES:
#
#    MALLOULI_DEVICE_ID:
#      ssh pi@192.168.1.147
#      cat /etc/salt/minion_id
#
#    MALLOULI_VEHICLE_ID:
#      Vérifier dans votre base de données backend
#      SELECT id FROM vehicles WHERE device_id = '...';
#
#    MALLOULI_API_TOKEN:
#      curl -X POST https://api.mallouliauto.tn/api/v1/auth/login \
#        -H "Content-Type: application/json" \
#        -d '{"email": "agent@...", "password": "..."}'
#      Copier le champ "access_token" ou "token"
#
# 2. TESTER LA CONFIGURATION:
#
#    source /etc/mallouli/agent.env
#    echo $MALLOULI_API_BASE_URL
#    python3 -c "import os; print(os.environ.get('MALLOULI_API_TOKEN'))"
#
# 3. DIAGNOSTIC:
#
#    # Voir les logs
#    journalctl -u mallouli-agent -f
#
#    # Voir le statut du service
#    systemctl status mallouli-agent
#
#    # Redémarrer après modification
#    sudo systemctl restart mallouli-agent
#
# 4. SÉCURITÉ:
#
#    ⚠️  Ne pas committer ce fichier avec le token réel dans Git!
#    ⚠️  Permissions: sudo chmod 600 /etc/mallouli/agent.env
#    ⚠️  Rotation du token régulièrement (ex: tous les 3 mois)
#
# ================================================================
